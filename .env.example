# =============================================================
# Copy to .env and fill in real values.  NEVER commit .env
# Read via python-decouple:  config("SECRET_KEY")
# =============================================================

# ---------- Django ----------
SECRET_KEY=replace-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ---------- Databases ----------
# B100 warehouse
DATABASE_URL=postgresql://postgres:password@localhost:5432/bluestock_dw

# Capstone geo-data API (NeonDB in production)
GEO_DATABASE_URL=postgresql://user:password@host.neon.tech/geodata

# Mutual Fund analytics
MF_DB_PATH=data/db/bluestock_mf.db

# ---------- Cache / broker ----------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---------- Power BI ----------
PBI_GATEWAY_TOKEN=

# ---------- External APIs ----------
MFAPI_BASE_URL=https://api.mfapi.in/mf

# ---------- Partner API ----------
HMAC_TIMESTAMP_TOLERANCE_SECONDS=300
API_KEY_HASH_ROUNDS=12

